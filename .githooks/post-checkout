#!/bin/sh
# post-checkout hook: automatically set upstream tracking for new branches.
#
# Git passes three arguments:
#   $1 = previous HEAD ref
#   $2 = new HEAD ref
#   $3 = flag (1 = branch checkout, 0 = file checkout)
#
# Only act on branch checkouts ($3 == 1).

PREV_HEAD="$1"
NEW_HEAD="$2"
BRANCH_CHECKOUT="$3"

[ "$BRANCH_CHECKOUT" = "1" ] || exit 0

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
[ -n "$BRANCH" ] || exit 0

# Skip if upstream is already set.
if git rev-parse --abbrev-ref --symbolic-full-name "@{upstream}" > /dev/null 2>&1; then
  exit 0
fi

# Try to set upstream to origin/<branch> if the remote ref exists.
if git ls-remote --exit-code origin "$BRANCH" > /dev/null 2>&1; then
  git branch --set-upstream-to="origin/$BRANCH" "$BRANCH" 2>/dev/null && \
    echo "[post-checkout] Tracking set: $BRANCH -> origin/$BRANCH"
fi

exit 0
